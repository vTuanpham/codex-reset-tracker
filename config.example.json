{
  "data_dir": "data",
  "state_path": "data/state.sqlite3",
  "runtime_dir": "data/runtime",
  "local_timezone": "auto",
  "time": {
    "user_timezone": "auto",
    "default_source_timezone": "America/Los_Angeles",
    "account_timezones": {
      "OpenAI": "America/Los_Angeles",
      "OpenAIDevs": "America/Los_Angeles",
      "ChatGPTapp": "America/Los_Angeles",
      "OpenAIStatus": "America/Los_Angeles",
      "sama": "America/Los_Angeles",
      "gdb": "America/Los_Angeles",
      "markchen90": "America/Los_Angeles",
      "nickaturley": "America/Los_Angeles",
      "kevinweil": "America/Los_Angeles",
      "thsottiaux": "America/Los_Angeles",
      "embirico": "America/Los_Angeles",
      "hansonwng": "America/Los_Angeles",
      "katyhshi": "America/Los_Angeles",
      "AnthropicAI": "America/Los_Angeles",
      "claudeai": "America/Los_Angeles",
      "ClaudeDevs": "America/Los_Angeles",
      "DarioAmodei": "America/Los_Angeles",
      "DanielaAmodei": "America/Los_Angeles",
      "jackclarkSF": "America/Los_Angeles",
      "mikeyk": "America/Los_Angeles",
      "ch402": "America/Los_Angeles",
      "bcherny": "America/Los_Angeles"
    }
  },
  "twitter": {
    "language": "en-US",
    "proxy": null,
    "user_agent": null,
    "cookies_file": "data/x_cookies.json",
    "username_env": "CODQ_X_USERNAME",
    "email_env": "CODQ_X_EMAIL",
    "password_env": "CODQ_X_PASSWORD",
    "totp_secret_env": "CODQ_X_TOTP_SECRET"
  },
  "polling": {
    "interval_seconds": 1200,
    "jitter_seconds": 45,
    "request_delay_seconds": 2.0,
    "alert_on_first_scan": false,
    "new_tweet_grace_seconds": 180,
    "tweet_count_per_account": 20,
    "search_count_per_query": 20,
    "max_alerts_per_scan": 10,
    "accounts": [
      "OpenAI",
      "OpenAIDevs",
      "ChatGPTapp",
      "OpenAIStatus",
      "sama",
      "gdb",
      "markchen90",
      "nickaturley",
      "kevinweil",
      "thsottiaux",
      "embirico",
      "hansonwng",
      "katyhshi",
      "AnthropicAI",
      "claudeai",
      "ClaudeDevs",
      "DarioAmodei",
      "DanielaAmodei",
      "jackclarkSF",
      "mikeyk",
      "ch402",
      "bcherny"
    ],
    "search_queries": [
      "from:OpenAI reset",
      "from:OpenAIDevs reset",
      "from:ChatGPTapp reset",
      "from:OpenAIStatus reset",
      "from:sama reset",
      "from:gdb reset",
      "from:markchen90 reset",
      "from:nickaturley reset",
      "from:kevinweil reset",
      "from:thsottiaux reset",
      "from:embirico reset",
      "from:hansonwng reset",
      "from:katyhshi reset",
      "from:AnthropicAI reset",
      "from:claudeai reset",
      "from:ClaudeDevs reset",
      "from:DarioAmodei reset",
      "from:DanielaAmodei reset",
      "from:jackclarkSF reset",
      "from:mikeyk reset",
      "from:ch402 reset",
      "from:bcherny reset"
    ]
  },
  "matching": {
    "case_sensitive": false,
    "require_all_include_patterns": true,
    "context_window_chars": 220,
    "include_patterns": [
      "\\breset(?:s|ting|ted)?\\b"
    ],
    "exclude_patterns": [
      "\\b(?:password\\s+reset|reset\\s+(?:your\\s+)?password|factory\\s+reset|hard\\s+reset|account\\s+recovery)\\b"
    ]
  },
  "notifications": {
    "title": "Potential Codex quota reset",
    "channels": {
      "stdout": {
        "enabled": true
      },
      "telegram": {
        "enabled": false,
        "bot_token_env": "CODQ_TELEGRAM_BOT_TOKEN",
        "chat_id_env": "CODQ_TELEGRAM_CHAT_ID"
      },
      "email": {
        "enabled": false,
        "smtp_host_env": "CODQ_SMTP_HOST",
        "smtp_port": 587,
        "smtp_username_env": "CODQ_SMTP_USERNAME",
        "smtp_password_env": "CODQ_SMTP_PASSWORD",
        "from_env": "CODQ_EMAIL_FROM",
        "to_env": "CODQ_EMAIL_TO",
        "starttls": true
      },
      "webhook": {
        "enabled": false,
        "url_env": "CODQ_WEBHOOK_URL",
        "format": "generic"
      },
      "desktop": {
        "enabled": false
      }
    }
  }
}
